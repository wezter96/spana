{
  "name": "spana-test",
  "version": "0.0.2",
  "description": "TypeScript-native E2E testing for React Native + Web",
  "keywords": [
    "android",
    "cross-platform",
    "e2e",
    "ios",
    "playwright",
    "react-native",
    "testing"
  ],
  "license": "Apache-2.0",
  "author": "Anton Wester",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wezter96/spana.git",
    "directory": "packages/spana"
  },
  "bin": {
    "spana": "dist/cli.js"
  },
  "files": [
    ".agents",
    "dist",
    "LICENSE",
    "README.md",
    "studio-dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./steps": {
      "types": "./dist/gherkin/steps.d.ts",
      "import": "./dist/gherkin/steps.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "test": "bun test",
    "test:e2e:framework-app": "bun run build && bun ./dist/cli.js test --config ./spana.config.ts",
    "test:watch": "bun test --watch",
    "check-types": "tsc --noEmit",
    "embed-studio": "bun scripts/embed-studio.ts",
    "postbuild": "bun scripts/embed-studio.ts"
  },
  "dependencies": {
    "@effect/cli": "^0.75.0",
    "@effect/platform": "^0.96.0",
    "@effect/platform-node": "^0.106.0",
    "@hono/node-server": "^1.19.12",
    "@orpc/client": "^1.13.13",
    "@orpc/server": "^1.13.13",
    "@orpc/zod": "^1.13.13",
    "effect": "^3.21.0",
    "hono": "^4.12.10",
    "playwright-core": "^1.49.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cucumber/cucumber-expressions": "^19.0.0",
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/messages": "^32.2.0",
    "@types/bun": "^1.2.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "@cucumber/cucumber-expressions": "^19.0.0",
    "@cucumber/gherkin": "^39.0.0",
    "@cucumber/messages": "^32.0.0"
  },
  "peerDependenciesMeta": {
    "@cucumber/cucumber-expressions": {
      "optional": true
    },
    "@cucumber/gherkin": {
      "optional": true
    },
    "@cucumber/messages": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "appium-uiautomator2-server": "^9.11.1",
    "appium-webdriveragent": "^11.4.1"
  }
}
