{
  "name": "spana",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "lucide-react": "^0.546.0",
      "next-themes": "^0.4.6",
      "sonner": "^2.0.5",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.1.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "prepare": "lefthook install && effect-language-service patch",
    "lint": "oxlint .",
    "test": "bun test packages",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:tui": "turbo -F tui dev",
    "studio": "bun run --cwd packages/spana dist/cli.js studio",
    "test:e2e:framework-app": "bun run --cwd packages/spana test:e2e:framework-app",
    "check": "bun run lint && oxfmt --write"
  },
  "dependencies": {
    "@spana/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/code-frame": "^7.29.0",
    "@effect/language-service": "^0.84.3",
    "@spana/config": "workspace:*",
    "@types/node": "^25.5.2",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "turbo": "^2.8.12",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.11"
}
